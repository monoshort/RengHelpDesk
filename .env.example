# Shopify (shop + admin token voor orders; client id/secret voor je app-registratie)
SHOPIFY_SHOP_DOMAIN=jouwwinkel.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Bij 401 na OAuth-refresh: automatisch nieuw Admin-token via client credentials (standaard aan). false = uit.
# SHOPIFY_AUTO_CC_ON_401=
# Admin API access token (Custom app in Shopify admin) — vereist om orders op te halen als je géén OAuth-bestand gebruikt
SHOPIFY_ACCESS_TOKEN=
# Op Vercel met zowel SHOPIFY_ACCESS_TOKEN als OAuth in de database: standaard wordt env-token eerst gebruikt (stabieler). false = OAuth eerst.
# SHOPIFY_ENV_TOKEN_FIRST=
# OAuth (/koppel.html): app vraagt verlopende offline tokens; .shopify_token.json bevat access + refresh en wordt server-side automatisch vernieuwd (zoals Gmail).
# API-versie (Shopify brengt oude versies uit dienst); bv. 2025-10
# SHOPIFY_API_VERSION=2025-10
# Alleen lokaal: als OAuth-callback "HMAC-validatie mislukt" geeft, tijdelijk true
# OAUTH_SKIP_HMAC_VERIFY=true

# OAuth: exact dezelfde URL als "Allowed redirection URL(s)" in de Shopify-app (host + poort moeten kloppen)
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback
# OAuth-scopes (custom app): read_orders + read_customers + read_products
# (read_products: productfoto's + productie-/levertijd uit body en product-metavelden, zoals "binnen X werkdagen")
# SHOPIFY_SCOPES=read_orders,read_customers,read_products
# Publieke winkel-URL voor productlinks in het dashboard (toddie: https://toddie.nl). Default: domein uit shop.json
# SHOPIFY_PUBLIC_STORE_URL=https://toddie.nl
# Admin API: harde timeout per request (ms), default 55000. OAuth refresh default 25000 ms.
# SHOPIFY_FETCH_TIMEOUT_MS=55000
# SHOPIFY_OAUTH_REFRESH_TIMEOUT_MS=25000
# Parallelle product-fetches (miniatuur per uniek product in de orderlijst)
# SHOPIFY_PRODUCT_FETCH_CONCURRENCY=8
# Max. orders in het dashboard (Shopify wordt pagina-voor-pagina uitgelezen). Standaard 250 — hoger = veel langzamer (mail-events per order).
# SHOPIFY_ORDERS_MAX=2000
# Alleen orders vanaf (nu − N dagen) ophalen via REST created_at_min. Standaard 90 (~3 maanden). 0 = geen ondergrens (alle datums; trager).
# SHOPIFY_ORDERS_CREATED_WITHIN_DAYS=90
# Alleen op Vercel: harde bovengrens voor /api/overview (default 96). Lager = sneller/ minder timeout; hoger = trager.
# ?limit= slaat deze cap over. Optioneel: /api/overview?mailLog=0 om mail-events over te slaan (veel sneller).
# SHOPIFY_VERCEL_OVERVIEW_ORDERS_MAX=72
# Parallelle timeline/mail-event fetches per order (1–20). Standaard 12.
# SHOPIFY_EVENTS_CONCURRENCY=12
# Max. orderregels met foto per order in de tabel (1–500). Standaard 250.
# SHOPIFY_ORDER_LINE_ITEMS_PREVIEW=250

# Order-/product-/mail-cache (snellere verversingen; eerstvolgende call haalt alleen gewijzigde orders)
# CACHE_DISABLED=true
# CACHE_DATA_DIR=./data
# CACHE_SQLITE_PATH=./data/overview-cache.db
# Postgres op Vercel/Railway: heeft voorrang op het sql.js-bestand hierboven
# DATABASE_URL=
# Met DATABASE_URL: Shopify OAuth-sessie standaard in Postgres (gedeeld tussen instances). Alleen bestand: SHOPIFY_SESSION_STORE=file
# Zelfde DATABASE_URL bewaart per dashboard-gebruiker (na login) Shopify + Gmail koppelingen (tabel reng_user_integrations).
# SHOPIFY_SESSION_STORE=file
# Marge vóór high-water tijdstempel voor incrementele sync (minuten)
# SYNC_OVERLAP_MINUTES=3
# Productfoto-cache TTL (ms), default 7 dagen
# PRODUCT_CACHE_TTL_MS=604800000
# Mail-timeline cache TTL (ms), default 6 uur
# MAIL_CACHE_TTL_MS=21600000
# Max aantal orders in DB voor mailbox-zoeken (zelfde cache als dashboard; default 250)
# MAIL_ORDER_SEARCH_CAP=250

# DPD NL Shipper webservices (delisId + wachtwoord van DPD)
DPD_DELIS_ID=
DPD_DELIS_PASSWORD=
# true = https://wsshippertest.dpd.nl (staging)
DPD_USE_STAGE=false
# Parallelle DPD-trackingcalls (per zending in de orderlijst). Standaard 6.
# DPD_TRACKING_CONCURRENCY=6

# AI: klantmail-concept + optioneel team-samenvatting van het order-overzicht (POST /api/ai/desk-insight)
# OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Gmail API (optioneel; als gekoppeld heeft dit voorrang op SMTP voor POST /api/mail/send)
# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Authorized redirect URIs in Google Cloud (exact, geen slash op het eind) — lokaal vaak beide:
#   http://localhost:3000/api/auth/gmail/callback
#   http://127.0.0.1:3000/api/auth/gmail/callback
# OAuth-scopes omvatten o.a. gmail.send + gmail.readonly (inbox op /mail.html).
# Lokaal: GOOGLE_REDIRECT_URI weglaten → app gebruikt host uit browser (match met bovenstaande URIs).
# Productie (Vercel): vaste URL, zelfde als in Google Cloud:
# GOOGLE_REDIRECT_URI=https://jouw-project.vercel.app/api/auth/gmail/callback
# Afzender (aanbevolen; anders opgeslagen na OAuth uit userinfo)
# GOOGLE_GMAIL_FROM=jouw@gmail.com
# Extra From-adressen (komma-gescheiden), bijv. info@toddie.nl — alleen als ze in Gmail “Verzenden als” of op SMTP staan
# MAIL_FROM_ALLOWLIST=info@toddie.nl,klantenservice@toddie.nl
# Serverless: refresh token handmatig (optioneel als je géén DATABASE_URL gebruikt)
# GOOGLE_GMAIL_REFRESH_TOKEN=
# true = negeer opgeslagen OAuth in DB; gebruik alleen GOOGLE_GMAIL_REFRESH_TOKEN (herstel als DB-token rot is)
# GOOGLE_GMAIL_FORCE_ENV=false
# OAuth prompt (spaties). Standaard: select_account consent. Alleen nodig bij verkeerd account: login select_account consent
# GOOGLE_GMAIL_OAUTH_PROMPT=
# true = bij zowel env- als DB-token: gebruik per-gebruiker DB-koppeling (standaard wint env zodat geen /gmail-koppel nodig is)
# GOOGLE_GMAIL_PREFER_USER_LINK=false
# GOOGLE_GMAIL_ACCESS_TOKEN=   (optioneel; liever weglaten — bij .google_gmail_token.json wordt na refresh automatisch bijgewerkt)
# GOOGLE_GMAIL_TOKEN_EXPIRY=  (unix ms, optioneel; idem)

# Uitgaande e-mail (helpdesk) — SMTP als alternatief voor Gmail API
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# true = verzenden altijd via SMTP als SMTP_* gevuld is (ook als Gmail OAuth voor inbox staat). Zo kun je info@domein via je host sturen.
# SMTP_SEND_FIRST=true
# Als login-adres ≠ From: envelope (MAIL FROM) vaak login; zet expliciet als je provider dat vereist
# SMTP_ENVELOPE_FROM=login@jouw-smtp-provider.nl
# Extra From-headers toegestaan (komma), naast SMTP_FROM — zie ook onder Gmail
# MAIL_FROM_ALLOWLIST=info@toddie.nl

# Dashboard (wachtwoord voor helpdesk-pagina's; default wachtwoord: RengTod123!)
# DASHBOARD_PASSWORD=
# Optioneel: vaste signing key voor sessiecookie (anders afgeleid van wachtwoord)
# DASHBOARD_SESSION_SECRET=
# Op productie (Render e.d.): zet op true — de server zet Secure alleen als het verzoek HTTPS is
# (lokaal http://localhost blijft werken zolang je niet echt over TLS gaat).
# DASHBOARD_COOKIE_SECURE=true
# Achter reverse proxy (Render, Railway, Vercel, …): vertrouw X-Forwarded-* headers
# TRUST_PROXY=true
#
# --- Vercel (serverless) ---
# Na deploy: SHOPIFY_REDIRECT_URI=https://<project>.vercel.app/api/auth/callback (zelfde in Shopify-app).
# Zet SHOPIFY_ACCESS_TOKEN + SHOPIFY_SHOP_DOMAIN in Vercel Environment (betrouwbaarder dan alleen OAuth-bestand).
# Optioneel: SHOPIFY_SESSION_FILE=/tmp/jouw_pad.json — default op Vercel is /tmp/reng_shopify_token.json
#
# Lokaal: npm run deploy:vercel (rond Vercel CLI-bug met Windows-paden met haakjes). Optioneel: VERCEL_PROJECT_NAME=jouw-vercel-projectnaam
